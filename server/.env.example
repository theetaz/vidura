# Postgres (Docker on the VPS). Local dev uses port 55432.
DATABASE_URL=postgres://postgres:viduradev@localhost:55432/vidura

# Public base URL of this API (used by better-auth for cookies/redirects).
# Local: http://localhost:8787 — Prod: https://vidura-api.nipuntheekshana.com
API_BASE_URL=http://localhost:8787

# The frontend origin allowed to call this API and receive auth cookies.
# Local: http://localhost:5173 — Prod: https://vidura.nipuntheekshana.com
WEB_ORIGIN=http://localhost:5173

# Secret for signing sessions/tokens (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET=dev-only-change-me-0000000000000000000000000000000000000000

# Google OAuth (from Google Cloud Console). Leave blank to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenRouter (translation + chat) — same keys you use today.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_CHAT_MODEL=

# Port the API listens on.
PORT=8787

# Optional residential proxy for YouTube transcript fetching (datacenter IPs
# are blocked by YouTube). e.g. http://user:pass@host:port. Empty = direct.
YOUTUBE_PROXY_URL=

# Path (inside container) to a Netscape cookies.txt from a logged-in YouTube
# session — bypasses the bot wall on flagged IPs. Mounted at /cookies.
YOUTUBE_COOKIES_FILE=/cookies/youtube.txt

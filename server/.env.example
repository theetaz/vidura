# Postgres (Docker on the VPS). Local dev uses port 55432.
DATABASE_URL=postgres://postgres:viduradev@localhost:55432/vidura

# Public base URL of this API (used by better-auth for cookies/redirects).
# Local: http://localhost:8787 — Prod: https://vidura-api.nipuntheekshana.com
API_BASE_URL=http://localhost:8787

# The frontend origin allowed to call this API and receive auth cookies.
# Local: http://localhost:5173 — Prod: https://vidura.nipuntheekshana.com
WEB_ORIGIN=http://localhost:5173

# Secret for signing sessions/tokens (generate: openssl rand -hex 32)
BETTER_AUTH_SECRET=dev-only-change-me-0000000000000000000000000000000000000000

# Google OAuth (from Google Cloud Console). Leave blank to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenRouter (translation + chat) — same keys you use today.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_CHAT_MODEL=

# Port the API listens on.
PORT=8787

# Residential proxy (Pay-As-You-Go, e.g. IPRoyal). Gives yt-dlp a clean IP so
# it can fetch YouTube's own frame-accurate caption track. Empty = Gemini only.
YOUTUBE_PROXY_URL=

# Transcript + metadata via official Google APIs — Google fetches the public
# YouTube URL server-side, so the VPS IP block doesn't apply. One Cloud Console
# API key works for both when these APIs are enabled on the project:
# "Generative Language API" (Gemini) and "YouTube Data API v3".
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
YOUTUBE_API_KEY=

# OpenAI single-shot translation (structured output). When set, translation
# uses one full-transcript call instead of the batched OpenRouter path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini-2026-03-17

{
  "name": "vidura-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "worker": "bun run src/worker.ts",
    "worker:dev": "bun run --watch src/worker.ts",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "auth:generate": "bunx @better-auth/cli generate --config src/auth.ts --output db/better-auth.sql -y",
    "db:apply": "bun run scripts/apply-schema.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "better-auth": "^1.6.23",
    "hono": "^4.12.31",
    "pg": "^8.22.0",
    "pg-boss": "^10.4.2",
    "postgres": "^3.4.9",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
